{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "api:dev": "node server/index.mjs",
    "start": "node server/index.mjs",
    "dev": "vite",
    "dev:local": "concurrently \"npm run api:dev\" \"npm run dev\"",
    "desktop:dev": "concurrently \"npm run api:dev\" \"vite --host 127.0.0.1 --port 8080\" \"node scripts/desktop-dev.mjs\"",
    "desktop:doctor-check": "node scripts/desktop-doctor-check.mjs",
    "desktop:cohort-health": "node scripts/desktop-cohort-health.mjs",
    "desktop:trace-sync": "node scripts/desktop-trace-sync.mjs",
    "desktop:export-diagnostics": "node scripts/desktop-export-diagnostics.mjs",
    "desktop:verify-rebuild": "node scripts/desktop-verify-rebuild.mjs",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:desktop": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:desktop:integration": "vitest run src/lib/desktopBridge.test.ts src/test/sync-route.test.ts",
    "verify:production": "node scripts/production-smoke.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed"
  },
