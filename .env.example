DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yk_apparels?schema=public"
API_PORT=4000
APP_ORIGIN="http://localhost:8080"
CORS_ALLOWED_ORIGINS="http://localhost:8080"
TRUST_PROXY=false
SESSION_TTL_HOURS=168
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
ALLOW_PROD_SEED=false
# Development can use local. Production should use s3 with Cloudflare R2/Backblaze B2 credentials.
UPLOAD_STORAGE_DRIVER=local
UPLOAD_LOCAL_DIR=uploads
UPLOAD_MAX_BYTES=5242880
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
